<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ YT Background Play"
            android:textColor="#FF0000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play YouTube with screen locked"
            android:textColor="#666666"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- STATUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textColor="#FF0000"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp" />

            <TextView android:id="@+id/statusOverlay"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="❌ Overlay: Not Granted"
                android:textColor="#CCCCCC" android:textSize="13sp" android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/statusAdmin"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="❌ Device Admin: Inactive"
                android:textColor="#CCCCCC" android:textSize="13sp" android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/statusAccessibility"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="❌ Accessibility: Disabled"
                android:textColor="#CCCCCC" android:textSize="13sp" android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/statusService"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="⚫ Service: Stopped"
                android:textColor="#CCCCCC" android:textSize="13sp"/>
        </LinearLayout>

        <!-- PERMISSIONS -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="STEP 1 — PERMISSIONS"
            android:textColor="#FF0000" android:textSize="11sp" android:letterSpacing="0.15"
            android:layout_marginBottom="10dp"/>

        <Button android:id="@+id/btnEnableOverlay"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Grant Overlay Permission"
            android:backgroundTint="#1A1A1A" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnEnableAdmin"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Activate Device Admin"
            android:backgroundTint="#1A1A1A" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnEnableAccessibility"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Enable Accessibility Service"
            android:backgroundTint="#1A1A1A" android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- METHOD SELECTOR -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="STEP 2 — CHOOSE METHOD"
            android:textColor="#FF0000" android:textSize="11sp" android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Try each method — different phones work best with different ones"
            android:textColor="#666666" android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <RadioGroup android:id="@+id/radioGroup"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Method A -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RadioButton android:id="@+id/radioMethodA"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🏠  Method A — Home + Lock"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:textStyle="bold"
                    android:buttonTint="#FF0000"
                    android:checked="true"/>

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Presses Home first so YouTube thinks you went home normally, then locks after 0.8s. Most compatible."
                    android:textColor="#888888" android:textSize="12sp"
                    android:layout_marginTop="4dp" android:layout_marginStart="32dp"/>
            </LinearLayout>

            <!-- Method B -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RadioButton android:id="@+id/radioMethodB"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚫  Method B — Fake Screen Off"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:textStyle="bold"
                    android:buttonTint="#FF0000"/>

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Shows a pure black overlay — screen appears off but YouTube never receives a lock event. Tap screen to return. Best for newer YouTube."
                    android:textColor="#888888" android:textSize="12sp"
                    android:layout_marginTop="4dp" android:layout_marginStart="32dp"/>
            </LinearLayout>

            <!-- Method C -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp">

                <RadioButton android:id="@+id/radioMethodC"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🎵  Method C — Audio Focus + Lock"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:textStyle="bold"
                    android:buttonTint="#FF0000"/>

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Claims audio focus from Android before locking, tricking the system into keeping the audio session alive through lock."
                    android:textColor="#888888" android:textSize="12sp"
                    android:layout_marginTop="4dp" android:layout_marginStart="32dp"/>
            </LinearLayout>

        </RadioGroup>

        <!-- START / STOP -->
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="STEP 3 — START SERVICE"
            android:textColor="#FF0000" android:textSize="11sp" android:letterSpacing="0.15"
            android:layout_marginBottom="10dp"/>

        <Button android:id="@+id/btnStartService"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="▶  START SERVICE"
            android:backgroundTint="#CC0000" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold"
            android:enabled="false"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnStopService"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="■  Stop Service"
            android:backgroundTint="#1A1A1A" android:textColor="#888888"
            android:layout_marginBottom="24dp"/>

        <!-- Tips -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💡 Tips"
                android:textColor="#FF0000" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="• Start with Method A — works on most devices\n• If audio still stops, try Method B (best for new YouTube)\n• Method C works well on some Realme/MIUI devices\n• Floating button is draggable — move it anywhere\n• Method B: tap black screen to return to YouTube"
                android:textColor="#888888" android:textSize="12sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
